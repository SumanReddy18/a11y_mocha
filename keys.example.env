# Copy this file to keys.env and fill in real values.
#   cp keys.example.env keys.env && chmod 600 keys.env
#
# keys.env is gitignored — never commit it.
# run.sh refuses to start if keys.env is tracked by git.

# Shared GitHub PAT (Contents:Read on browserstack/browserstack-node-agent).
# Used during `docker build` to fetch the private SDK tarball.
GITHUB_TOKEN=ghp_replace_me
RENGG_BROWSERSTACK_USERNAME=rengg_user
RENGG_BROWSERSTACK_ACCESS_KEY=rengg_key

REGRESSION_BROWSERSTACK_USERNAME=regression_user
REGRESSION_BROWSERSTACK_ACCESS_KEY=regression_key

PREPROD_BROWSERSTACK_USERNAME=preprod_user
PREPROD_BROWSERSTACK_ACCESS_KEY=preprod_key

PROD_BROWSERSTACK_USERNAME=prod_user
PROD_BROWSERSTACK_ACCESS_KEY=prod_key
